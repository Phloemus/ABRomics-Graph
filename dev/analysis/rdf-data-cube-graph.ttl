    qb:dataSet ns1:reportDataset .

ns1:reportDataset1 a qb:DataSet ;
    rdfs:label "Analysis results report #1"^^xsd:string ;
    dcterms:title "Analysis results report"^^xsd:string ;
    qb:slice ns1:wholeReportSlice1 ;
    qb:sliceKey ns1:targetAntibioticSliceK ;
    rdfs:comment "Comments about the dataset"^^xsd:string .
    
ns1:reportDataset2 a qb:DataSet ;
    rdfs:label "Analysis results report #2"^^xsd:string ;
    dcterms:title "Analysis results report"^^xsd:string ;
    qb:slice ns1:wholeReportSlice2 ;
    qb:sliceKey ns1:targetAntibioticSliceK ;
    rdfs:comment "Comments about the dataset"^^xsd:string .