############################# Results of Observations ######################################

# The result entity allows to hold the value (the measure) of the observation.
# A result also contains a unit that gives further informations about the 
# observation made 

###### Results for Observations with the strain1 / sample 1 / name of the resistance genes
<r1> rdf:type sosa:Result ; 
        sosa:hasValue "blaTEM-1A" ;
        sosa:hasUnit "Gene name" ; # in unit ontology ? 
        sosa:resultTime "2024-05-30T12:36:12Z"^^xsd:dateTime .

<r2> rdf:type sosa:Result ; 
        sosa:hasValue "tet(A)" ;
        sosa:hasUnit "Gene name" ; # in unit ontology ? 
        sosa:resultTime "2024-05-30T12:36:12Z"^^xsd:dateTime .

