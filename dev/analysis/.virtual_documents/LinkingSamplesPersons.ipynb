


import uuid

index_samples = {}

def genSample(j):
    uri = ""
    if j in index_samples.keys():
        uri = index_samples[j]
    else:
        uri = f"{prefix}Sample#{uuid.uuid1()}"    
    
    s = f"""<{uri}> rdf:type abr:Sample ; schema:identifier "{j}".\n"""
    index_samples[j] = uri
    return s,uri

def genPerson():
    i = uuid.uuid1() 
    uri = f"{prefix}Person#{i}"
    s = f"<{prefix}Person#{i}> rdf:type foaf:Person .\n"
    return s,uri

