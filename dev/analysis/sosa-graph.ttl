############################# Results of Observations ######################################

# The observable property define the meaning of what is the result of the 
# observation is. The result should be the answer of the observable property
# (ex: ObservableProperty:Height, Result:20m). Feature of interest and 
# observable property have very close definitions, the only difference is that
# the observation property is more precised than the feature of interest (which
# have definitions that should fit to multiple observations of the SAME sample)

###### Observation Property (the resistance gene name)
<ABRgenes> rdf:type sosa:ObservableProperty ;
        rdfs:label "Antibiotic resistant gene names"^^xsd:string .

###### Observation Property (the resistance gene name)
<ABRgenesCov> rdf:type sosa:ObservableProperty ;
        rdfs:label "Antibiotic resistant gene coverage"^^xsd:string .

<ABRantibiotic> rdf:type sosa:ObservableProperty ;
        rdfs:label "Antibiotic name"^^xsd:string .


############################### Sensors (workflows) #######################################

# A sensor is a specification of a plan of execution. Corresponds to the code 
# of a workflow
abromics:WF1_impl rdf:type sosa:Sensor ; 
        sosa:implements abromics:WF1_spec ;
        sosa:isHostedBy abromics:NNCR .


############################## Plateform (location) #######################################

# In the context of the ABRomics project, a plateform is a physical location
# that hosts the sensor that made an observation.
abromics:NNCR rdf:type sosa:Platform .


################################# Procedures  #############################################

# The procedure is an implementation of a plan of execution (a sensor). Multiple
# procedures coming from the same sensor can be performed at different time and 
# at different locations.
abromics:WF1_spec rdf:type sosa:Procedure ;
        sosa:isImplementedBy abromics:WF1_impl .


########################## Strain Feature of Interest ####################################

# Strains can be seen a "sub features" present within a sample. It's defined as a 
# sosa:FeatureOfInterest to allow filtration of the strain from sample observations
# Inference of the knowledge found in all the observations linked to the strain directly 
# to the strain class (resistance genes, resistance antibiotics..)
<strain_1> rdf:type sosa:FeatureOfInterest, 
                    aro:Strain ;
        obo:RO_0002162 <http://purl.uniprot.org/taxonomy/562> ; #in_taxon E. Coli
        aro:confers_resistance_to_antibiotic aro:ampicillin ;
        aro:confers_resistance_to_antibiotic aro:tetracycline ;
        aro:confers_resistance_to_antibiotic aro:sulfisoxazole ;
        aro:confers_resistance_to_antibiotic aro:trimethoprim ;
        aro:confers_resistance_to_antibiotic aro:streptomycin .


########################### Genes Feature of Interest ###################################

# The gene is not always indicated as the feature of interest for an observation 
# because the observation may not be focused on a specific gene. This feature of 
# interest allows to target more specifically a gene but this field may be 
# very verstile depending on the observation
<gene_1> rdf:type sosa:FeatureOfInterest  ; 
        rdf:type go:Gene ; 
        schema:identifier uniprot:blaTEM-1A .

<gene_2> rdf:type sosa:FeatureOfInterest  ; 
        rdf:type go:Gene ; 
        schema:identifier uniprot:tetA . ##! problem with parenthesis in the real name of the gene: tet(A)

<gene_3> rdf:type sosa:FeatureOfInterest  ; 
        rdf:type go:Gene ; 
        schema:identifier uniprot:sul1 .

<gene_4> rdf:type sosa:FeatureOfInterest  ; 
        rdf:type go:Gene ; 
        schema:identifier uniprot:qacE .

<gene_5> rdf:type sosa:FeatureOfInterest  ; 
        rdf:type go:Gene ; 
        schema:identifier uniprot:dfrA1 .

<gene_6> rdf:type sosa:FeatureOfInterest  ; 
        rdf:type go:Gene ; 
        schema:identifier uniprot:aadA1 .


########################### Location Feature of Interest ################################
        
# The location of the sample is also a feature of interest, as we can consider that 
# the location is a trait of a sample that can be observed only when the extraction
# of the sample from is natural medium has been made.
<S1#location> rdf:type sosa:FeatureOfInterest ;
  rdfs:label "location of S1"@en ;
  geo:lat 35.8648067 ;
  geo:long -120.6195831 ;
  geo:alt 12.75 .
