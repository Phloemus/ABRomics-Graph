@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix schema: <https://schema.org/> .
@prefix abromics: <https://abromics.fr/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix aro: <http://purl.obolibrary.org/obo/aro.owl#> .
@prefix go: <http://purl.org/obo/owl/GO#> .
@prefix uniprot: <http://purl.uniprot.org/uniprot/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

################################### Samples #############################################

# Samples refer as biological samples extracted from a patient of from 
# a natural source (water or soil). They are subject to multiple observations.
# Observations of the sample can be focused to a specific feature of contained
# within the sample.

###### Sample 1 
<sample_1> rdf:type sosa:FeatureOfInterest ; 
        schema:identifier "0001" ; 
        abromics:collection_date "2023-02-03" ; 
        abromics:has_latitude "98.877293" ; 
        abromics:has_longitude "45.874" .


################################  Observations #########################################

# Observations are made by a workflow implementing a procedure. An observation
# yield a measure (result) of multiple features of interest and a unique 
# observable property. The main feature of interest is the sample but the 
# observation is also focused on other features that are found within the 
# sample like a strain or a gene for instance.
# Those features of interest allow to filter the observations when quering 
# the ABRomics knowledge graph

###### Observation for the strain1 / sample 1 / name of the resistance genes
<obs_s1_1> rdf:type sosa:Observation ; 
        sosa:hasFeatureOfInterest <strain_1> ; 
        sosa:hasFeatureOfInterest <sample_1> ; 
        sosa:hasFeatureOfInterest <gene_1> ; 
        sosa:hasFeatureOfInterest <S1#location> ;
        sosa:hasObservableProperty <ABRgenes> ; 
        sosa:madeBySensor abromics:WF1_impl ;
        sosa:usedProcedure abromics:WF1_spec ;
        sosa:hasResult <r1> .

<obs_s1_2> rdf:type sosa:Observation ; 
        sosa:hasFeatureOfInterest <strain_1> ; 
        sosa:hasFeatureOfInterest <sample_1> ; 
