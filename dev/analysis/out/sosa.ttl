############################# Observable propertues ########################################


    <Resistance_gene> rdf:type sosa:ObservableProperty ;
        rdfs:label "Resistance gene"^^xsd:string .

    <Gene_length> rdf:type sosa:ObservableProperty ;
        rdfs:label "Gene length"^^xsd:string .

    <Identity_percent> rdf:type sosa:ObservableProperty ;
        rdfs:label "Identity %"^^xsd:string .

    <Coverage_percent> rdf:type sosa:ObservableProperty ;
        rdfs:label "Coverage %"^^xsd:string .

    <Contig> rdf:type sosa:ObservableProperty ;
        rdfs:label "Contig"^^xsd:string .

    <Start_in_contig> rdf:type sosa:ObservableProperty ;
        rdfs:label "Start in contig"^^xsd:string .

    <End_in_contig> rdf:type sosa:ObservableProperty ;
        rdfs:label "End in contig"^^xsd:string .

    <Strand> rdf:type sosa:ObservableProperty ;
        rdfs:label "Strand"^^xsd:string .

    <Antibiotic_class> rdf:type sosa:ObservableProperty ;
        rdfs:label "Antibiotic class"^^xsd:string .

    <Target_antibiotic> rdf:type sosa:ObservableProperty ;
        rdfs:label "Target antibiotic"^^xsd:string .

    <Accession_number> rdf:type sosa:ObservableProperty ;
        rdfs:label "Accession number"^^xsd:string .



