## Environment variables

# Version
IS_DEV="true"

# Nginx
NGINX_CONF_FILE="nginx.dev.conf"
NGINX_HTTP_PORT=8081
NGINX_HTTPS_PORT=8082

# API
API_HOST="graph-api" 
API_BASEPATH="graph-api"
API_PORT=5000
API_ADMIN_USERNAME="admin"
API_ADMIN_PASSWORD="admin"

# Virtuoso
VIRTUOSO_HOST="virtuoso"
VIRTUOSO_PORT=8890

HTTP="http://"
