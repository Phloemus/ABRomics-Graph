## Environment variables

# Version
IS_DEV="true"

# Hostname
HOST_URL="http://localhost:8081"

# Nginx
NGINX_CONF_FILE="nginx.conf"
NGINX_HTTP_PORT=8081
NGINX_HTTPS_PORT=8082

# API
API_HOST="localhost" 
API_BASEPATH="graph-api"
API_PORT=8081
API_ADMIN_USERNAME="admin"
API_ADMIN_PASSWORD="admin"

# Graph server
GRAPH_SERVER_HOST="http://graphdb:7200/"
GRAPH_SERVER_PORT=7200

HTTP="http://"
