## environment variables
#
# Rename this file to .env and indicate your own environment variables

# Nginx
NGINX_CONF_FILE="nginx.dev.conf"
NGINX_HTTP_PORT=8081
NGINX_HTTPS_PORT=8082

# API
API_HOST="graph-api"
API_BASEPATH="api"
API_PORT=5000
FLASK_ENV="development" # can be switched to "production"

# Virtuoso
VIRTUOSO_HOST="virtuoso"
VIRTUOSO_PORT=8890

HTTP="http://"
