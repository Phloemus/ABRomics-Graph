PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sio: <http://semanticscience.org/resource/>

## count the number of samples for all the sample types

SELECT ?sampleType (COUNT(?sample) as ?total_nb_occurences) 
FROM <http://www.ontotext.com/explicit> ## Indicates to graphdb to only use explicit nodes and no other inference reasonner
WHERE {
        ?sample rdf:type sio:001050 ;
                sio:000068 [ rdfs:label ?sampleType ] .

}
GROUP BY ?sampleType
