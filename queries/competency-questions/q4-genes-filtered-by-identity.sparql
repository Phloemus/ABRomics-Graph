PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX sio: <http://semanticscience.org/resource/>
PREFIX schema: <https://schema.org/>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ncit: <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl>
PREFIX aro: <http://purl.obolibrary.org/obo/ARO_>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?gene_name ?identity
FROM <http://www.ontotext.com/explicit>
WHERE {
    ?sample rdf:type sio:001050 ;
        schema:identifier "ABRA002126" .

    ?observableProperty rdf:type sosa:ObservableProperty ;
        rdfs:label 'Identity (%)' .

    ?observations sosa:observedProperty ?observableProperty ;
        sio:000332 ?sample ;
        sosa:hasFeatureOfInterest ?gene ;
        sosa:hasSimpleResult ?identity .

    ?gene rdf:type ncit:C16612 ;
          rdf:type [ rdfs:subClassOf+ aro:3000000 ] ;
        rdfs:label ?gene_name .

}
GROUP BY ?gene_name ?identity
ORDER BY DESC(?identity) # sort the result by the most identity % detected
