@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rep: <http://www.openrdf.org/config/repository#> .
@prefix sail: <http://www.openrdf.org/config/sail#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<abromicsKG> a rep:Repository;
    rep:repositoryID "abromics-kg";
    rep:repositoryImpl [
        rep:repositoryType "graphdb:SailRepository";
        <http://www.openrdf.org/config/repository/sail#sailImpl> [
            <http://www.ontotext.com/config/graphdb#base-URL> "http://graph.abromics.fr";
            <http://www.ontotext.com/config/graphdb#check-for-inconsistencies> "false";
            <http://www.ontotext.com/config/graphdb#defaultNS> "abromics";
            <http://www.ontotext.com/config/graphdb#disable-sameAs> "true";
            <http://www.ontotext.com/config/graphdb#enable-context-index> "false";
            <http://www.ontotext.com/config/graphdb#enable-fts-index> "false";
            <http://www.ontotext.com/config/graphdb#enable-literal-index> "true";
            <http://www.ontotext.com/config/graphdb#enablePredicateList> "true";
            <http://www.ontotext.com/config/graphdb#entity-id-size> "32";
            <http://www.ontotext.com/config/graphdb#entity-index-size> "100000000";
            <http://www.ontotext.com/config/graphdb#fts-indexes> ("default" "iri");
            <http://www.ontotext.com/config/graphdb#fts-iris-index> "none";
            <http://www.ontotext.com/config/graphdb#fts-string-literals-index> "default";
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/aro.owl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/envo.owl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/genes.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/linksSamplesObservations.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/ncit.owl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/observableProperties.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/observations.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/ohmi.owl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/people.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/platforms.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/procedures.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/ro.owl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/samples.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/sensors.ttl" ;
            <http://www.ontotext.com/config/graphdb#imports> "/root/graphdb-import/strains.ttl" ;
            <http://www.ontotext.com/config/graphdb#in-memory-literal-properties> "true";
            <http://www.ontotext.com/config/graphdb#query-limit-results> "0";
            <http://www.ontotext.com/config/graphdb#query-timeout> "0";
            <http://www.ontotext.com/config/graphdb#read-only> "false";
            <http://www.ontotext.com/config/graphdb#repository-type> "file-repository";
            <http://www.ontotext.com/config/graphdb#ruleset> "rdfsplus-optimized";
            <http://www.ontotext.com/config/graphdb#storage-folder> "storage";
            <http://www.ontotext.com/config/graphdb#throw-QueryEvaluationException-on-timeout>
            "false";
            sail:sailType "graphdb:Sail"
        ]
    ];
    rdfs:label "" .

# ;/root/graphdb-import/envo.owl;/root/graphdb-import/genes.ttl;/root/graphdb-import/linksSamplesObservations.ttl;/root/graphdb-import/ncbitaxon.owl;/root/graphdb-import/ncit.owl;/root/graphdb-import/observableProperties.ttl;/root/graphdb-import/observations.ttl;/root/graphdb-import/ohmi.owl;/root/graphdb-import/people.ttl;/root/graphdb-import/platforms.ttl;/root/graphdb-import/procedures.ttl;/root/graphdb-import/ro.owl;/root/graphdb-import/samples.ttl;/root/graphdb-import/sensors.ttl;/root/graphdb-import/strains.ttl;/root/graphdb-import/uberon.owl
