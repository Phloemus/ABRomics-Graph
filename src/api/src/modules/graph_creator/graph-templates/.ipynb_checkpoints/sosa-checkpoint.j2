################################### Samples #############################################

{% for sampleId, sample in enumerate(templateVars["samples"]) %}
    <sample_{sampleId}> rdf:type sosa:FeatureOfInterest ;
            rdf:type sio:001050 ; 
            schema:identifier "000{sampleId}" ; 
            abromics:collection_date "2023-02-03" ; 
            abromics:has_latitude "98.877293" ; 
            abromics:has_longitude "45.874" .
{% endfor %}
