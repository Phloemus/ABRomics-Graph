FROM node:20-alpine

COPY src app/src
COPY package.json app
COPY tsconfig.json app
COPY nuxt.config.ts app

WORKDIR app

ARG HTTP
ENV NUXT_PUBLIC_HTTP=$HTTP

ARG HOST_URL
ENV NUXT_PUBLIC_HOST_URL=$HOST_URL

ARG GRAPH_SERVER_HOST
ENV NUXT_PUBLIC_GRAPH_SERVER_HOST=$GRAPH_SERVER_HOST

ARG API_HOST
ENV NUXT_PUBLIC_API_HOST=$API_HOST

ARG API_PORT
ENV NUXT_PUBLIC_API_PORT=$API_PORT

ARG API_BASEPATH
ENV NUXT_PUBLIC_API_BASEPATH=$API_BASEPATH

RUN npm install
RUN npm run build

ENV PORT=3000
ENV HOST=0.0.0.0

EXPOSE 3000

CMD ["npm", "run", "start"]
